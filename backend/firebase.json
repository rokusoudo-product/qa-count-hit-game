{
  "functions": {
    "source": "functions",
    "runtime": "python312",
    "ignore": [
      "venv",
      "__pycache__",
      "*.pyc",
      ".env"
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "web",
    "ignore": [
      "firebase.json",
      "**/.*"
    ]
  }
}
